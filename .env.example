# Copy to .env and fill in. Streamlit can also read from .streamlit/secrets.toml

# OpenAI
OPENAI_API_KEY=

# Google Gemini（官方直连）
GOOGLE_API_KEY=

# Default provider: gemini | relay | openai
AI_PROVIDER=gemini

# Gemini 官方直连模型名
GEMINI_MODEL=gemini-2.0-flash

# OpenAI 官方模型名
OPENAI_MODEL=gpt-4o-mini

# ---------- 中转 API（魔芋等，一般为 OpenAI Chat Completions 兼容，文档示例见下）----------
# GEMINI_RELAY_BASE_URL=http://101.200.167.88:8001/v1
# GEMINI_RELAY_API_KEY=你的中转密钥
# GEMINI_RELAY_MODEL=Gemini 3.1 Flash-Lite
